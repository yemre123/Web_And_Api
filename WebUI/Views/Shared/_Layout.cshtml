<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FanSchedule UI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: "class"
        };
    </script>
    <script>
        document.documentElement.classList.add("dark");
    </script>
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-slate-950 text-slate-100">
    <header class="border-b border-slate-800 bg-slate-900/90 backdrop-blur">
        <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
            <a class="text-base font-semibold tracking-wide text-slate-100" asp-area="" asp-controller="FanSchedules" asp-action="Index">FanSchedule UI</a>
            <div class="flex items-center gap-4 text-sm">
                <a class="text-slate-300 transition hover:text-sky-300" asp-area="" asp-controller="FanSchedules" asp-action="Index">Schedules</a>
                <a class="text-slate-300 transition hover:text-sky-300" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </nav> 
    </header>
    <div class="mx-auto max-w-6xl px-4 py-6">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-8 border-t border-slate-800 py-5 text-center text-sm text-slate-400">
        <div class="mx-auto max-w-6xl px-4">
            &copy; 2026 - FanSchedule UI
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
